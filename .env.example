# Optional editorial ingestion tokens. Never expose them with NEXT_PUBLIC_.
OPENNEWS_TOKEN=
TWITTER_TOKEN=

# Optional. Coinbase's current public-products documentation may require a CDP bearer token.
COINBASE_CDP_BEARER_TOKEN=

# Production market snapshot storage. Keep the standard token server-side only.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
MARKET_STREAM_SYMBOLS=BTC,ETH,SOL,XRP,DOGE,ADA,AVAX,LINK,LTC,BCH,BNB,SUI

# Public Railway stream gateway. Configure this in the web deployment and redeploy.
NEXT_PUBLIC_MARKET_STREAM_URL=https://stone-daily-production.up.railway.app

# Railway worker controls. Direct SSE remains one-second; Redis is only a fallback snapshot.
MARKET_STREAM_BROADCAST_MS=1000
MARKET_STREAM_REDIS_FLUSH_MS=10000
MARKET_STREAM_REDIS_TTL_SECONDS=40
MARKET_STREAM_MAX_CLIENTS=500
MARKET_STREAM_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Protects /api/internal/markets/sync. Vercel Cron sends it as a Bearer token.
CRON_SECRET=

# Optional: enable filesystem snapshots in a persistent non-Vercel production runtime.
STONE_ENABLE_FILE_CACHE=0
