{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.web",
    "watchPatterns": [
      "app/**",
      "components/**",
      "data/**",
      "hooks/**",
      "public/**",
      "services/**",
      "src/**",
      "types/**",
      "Dockerfile.web",
      "next.config.ts",
      "package.json",
      "package-lock.json",
      "railway.web.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/",
    "healthcheckTimeout": 180,
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10,
    "overlapSeconds": 10,
    "drainingSeconds": 20
  }
}
